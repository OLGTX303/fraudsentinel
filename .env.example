# ── Google Cloud / Gemini ─────────────────────────────────────────
# FraudSentinel reasons with Google Gemini via the google-genai SDK.
# Pick ONE of the two auth modes below.

# Model to use (gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro,
# or a preview such as gemini-3-pro-preview).
GEMINI_MODEL=gemini-2.0-flash

# --- Mode A: Vertex AI (recommended for Cloud Run / Agent Builder) ---
# Uses Application Default Credentials — no API key in the container.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Mode B: Gemini API key (simplest for local dev) ---------------
# If set, this takes precedence when GOOGLE_GENAI_USE_VERTEXAI is unset.
GOOGLE_API_KEY=your-gemini-api-key

# ── Arize AI (partner MCP / observability track) ──────────────────
ARIZE_API_KEY=your-arize-api-key
ARIZE_SPACE_ID=your-arize-space-id
ARIZE_MODEL_ID=fraudsentinel-v1

# ── App settings ──────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
DEMO_MODE=true          # Uses mock data instead of real external APIs
LOG_LEVEL=INFO
